{
  "pipeline_name": "intent_classifier_validation",
  "description": "Pipeline validation with 100 synthetic samples. Not for production accuracy.",

  "data_sources": [
    {
      "source_type": "synthetic",
      "name": "validation_synthetic",
      "weight": 1.0,
      "params": {
        "total_examples": 100,
        "use_ollama": false
      }
    }
  ],

  "preprocessing": {
    "use_text_cleaner": true,
    "use_deduplication": true,
    "min_text_length": 10
  },

  "training": {
    "trainer_type": "intent_classifier",
    "model_name": "bert-base-uncased",
    "num_labels": 31,
    "num_epochs": 2,
    "batch_size": 16,
    "learning_rate": 1e-5,
    "max_length": 128,
    "output_dir": "models/intent_classifier"
  },

  "evaluation": {
    "enabled": true,
    "report_path": "models/intent_classifier/evaluation_report.json"
  },

  "export": {
    "mlflow": {
      "enabled": false,
      "tracking_uri": "http://localhost:5000",
      "experiment_name": "intent_classifier_validation",
      "register_model": false,
      "model_name": "intent-classifier"
    },
    "publish_model_ready": false
  },

  "split": {
    "train_ratio": 0.70,
    "val_ratio": 0.15,
    "test_ratio": 0.15,
    "seed": 42
  }
}
